# ── Anthropic (LLM-2: full-text screening, quality assessment, DTA rescreen) ──
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI-compatible endpoint (LLM-1: abstract screening, PICO extraction) ──
# BFH internal endpoint — substitute any OpenAI-compatible provider externally
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://inference.mlmp.ti.bfh.ch/api/v1
OPENAI_MODEL=gpt:oss120b

# ── PubMed ────────────────────────────────────────────────────────────────────
PUBMED_API_KEY=
PUBMED_EMAIL=your_email@example.com

# ── Semantic Scholar (optional, raises rate limit) ────────────────────────────
# Register free key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Unpaywall full-text retrieval (required) ──────────────────────────────────
UNPAYWALL_EMAIL=your_email@example.com

# ── CASCADE-RC concurrency ────────────────────────────────────────────────────
# Max PMIDs processed in parallel during score_u (each fires B=5 LLM calls).
# Peak concurrent API calls = CRC_N_CONCURRENT × 5.
# Start at 20 (100 concurrent calls); raise to 40 if no HTTP 429 errors appear.
CRC_N_CONCURRENT=20